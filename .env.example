# GHCR images used by docker-compose.yml (default stack)
ENGINE_IMAGE=ghcr.io/your-org/mt5-fleet-engine:latest
API_IMAGE=ghcr.io/your-org/mt5-fleet-api:latest

# Port the dashboard is published on
WEB_PORT=17380

# Number of RPyC worker ports to publish (workers get 18812, 18813, ...)
# Adjust if you need more than 100 concurrent workers
WORKER_PORT_RANGE_START=18812
WORKER_PORT_RANGE_END=18912

# VNC WebSocket published port range (host) mapped to 6800-6900 (container)
VNC_WS_PORT_RANGE_START=19000
VNC_WS_PORT_RANGE_END=19100
