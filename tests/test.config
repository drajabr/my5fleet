# RPyC manual trade-flow test configuration
# Format: key=value
# Lines starting with # or ; are comments.

api_base=http://localhost:17380/api
rpyc_host=localhost
# Leave worker_id empty to create from scratch each run (recommended for first-time usage)
worker_id=
worker_name=rpyc-shell-e2e

# Leave token empty when auto_create_worker=true (script will generate one)
token=
login=12345678
password=REPLACE_WITH_ACCOUNT_PASSWORD
server=REPLACE_WITH_BROKER_SERVER

# Optional overrides
auto_create_worker=true
cleanup_created_worker=false
symbol=XAUUSD
magic=20260421
comment=my5fleet-rpyc-test
wait_timeout=180
